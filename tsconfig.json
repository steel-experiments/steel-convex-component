{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": true,

    "target": "ESNext",
    "lib": ["ES2021", "dom", "DOM.Iterable"],
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "noErrorTruncation": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "composite": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/index.ts",
    "./src/client/index.ts",
    "./src/test.ts",
    "./src/component/convex.config.ts",
    "./src/component/schema.ts",
    "./src/component/steel.ts",
    "./src/component/normalize.ts",
    "./src/component/sessions.ts",
    "./src/component/_generated/**/*.ts"
  ]
}
