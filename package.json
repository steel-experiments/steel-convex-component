{
  "name": "steel-convex-component",
  "version": "0.1.0",
  "description": "Convex component wrapper for Steel",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "codegen": "convex codegen --component-dir ./src/component",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/sessions.unit.test.ts",
    "test:integration": "vitest run test/sessions.integration.test.ts",
    "release:verify": "node scripts/release-verify.js",
    "release:check": "npm run build && npm run release:verify && npm run test",
    "release": "npm run release:check",
    "publish:dry-run": "npm run release:check && npm pack --dry-run",
    "release:publish": "npm run release && npm publish --access public",
    "prepublishOnly": "npm run build && npm run test"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "default": "./_generated/component.js"
    },
    "./_generated/component": {
      "default": "./_generated/component.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "default": "./dist/test.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "convex": "^1.32.0"
  },
  "dependencies": {
    "steel-sdk": "^0.17.0"
  },
  "devDependencies": {
    "convex-test": "^0.0.41",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
